#include "roBa.dtsi"

&default_transform {
    col-offset = <6>;
};

&kscan0 {
        col-gpios
            = <&xiao_d 10 GPIO_ACTIVE_HIGH>
            , <&xiao_d 9 GPIO_ACTIVE_HIGH> 
            , <&xiao_d 8 GPIO_ACTIVE_HIGH> 
            , <&xiao_d 7 GPIO_ACTIVE_HIGH> 
            , <&gpio0 10 GPIO_ACTIVE_HIGH>
            ;
};

/ {
    // 可変感度用の入力プロセッサ定義（加速度カーブ効果）
    trackball_processors {
        // 超精密モード - 0.3倍（微細作業用）
        trackball_ultra_slow: trackball_ultra_slow {
            compatible = "zmk,input-processor-scaler";
            #input-processor-cells = <0>;
            scaling-factor-numerator = <3>;
            scaling-factor-denominator = <10>;
            type = <INPUT_EV_REL>;
            codes = <INPUT_REL_X INPUT_REL_Y>;
        };

        // 低速移動用（高精度）- 0.6倍
        trackball_slow: trackball_slow {
            compatible = "zmk,input-processor-scaler";
            #input-processor-cells = <0>;
            scaling-factor-numerator = <3>;
            scaling-factor-denominator = <5>;
            type = <INPUT_EV_REL>;
            codes = <INPUT_REL_X INPUT_REL_Y>;
        };

        // 中低速モード - 0.8倍
        trackball_medium_slow: trackball_medium_slow {
            compatible = "zmk,input-processor-scaler";
            #input-processor-cells = <0>;
            scaling-factor-numerator = <4>;
            scaling-factor-denominator = <5>;
            type = <INPUT_EV_REL>;
            codes = <INPUT_REL_X INPUT_REL_Y>;
        };

        // 標準移動用（通常）- 1.0倍  
        trackball_normal: trackball_normal {
            compatible = "zmk,input-processor-scaler";
            #input-processor-cells = <0>;
            scaling-factor-numerator = <1>;
            scaling-factor-denominator = <1>;
            type = <INPUT_EV_REL>;
            codes = <INPUT_REL_X INPUT_REL_Y>;
        };

        // 中高速モード - 1.4倍
        trackball_medium_fast: trackball_medium_fast {
            compatible = "zmk,input-processor-scaler";
            #input-processor-cells = <0>;
            scaling-factor-numerator = <7>;
            scaling-factor-denominator = <5>;
            type = <INPUT_EV_REL>;
            codes = <INPUT_REL_X INPUT_REL_Y>;
        };

        // 高速移動用（快速）- 2.0倍
        trackball_fast: trackball_fast {
            compatible = "zmk,input-processor-scaler";
            #input-processor-cells = <0>;
            scaling-factor-numerator = <2>;
            scaling-factor-denominator = <1>;
            type = <INPUT_EV_REL>;
            codes = <INPUT_REL_X INPUT_REL_Y>;
        };

        // 超高速モード - 3.0倍（快速ナビゲーション）
        trackball_ultra_fast: trackball_ultra_fast {
            compatible = "zmk,input-processor-scaler";
            #input-processor-cells = <0>;
            scaling-factor-numerator = <3>;
            scaling-factor-denominator = <1>;
            type = <INPUT_EV_REL>;
            codes = <INPUT_REL_X INPUT_REL_Y>;
        };

        // スクロール用 - 0.25倍（精密スクロール）
        trackball_scroll: trackball_scroll {
            compatible = "zmk,input-processor-scaler";
            #input-processor-cells = <0>;
            scaling-factor-numerator = <1>;
            scaling-factor-denominator = <4>;
            type = <INPUT_EV_REL>;
            codes = <INPUT_REL_X INPUT_REL_Y>;
        };
    };

    trackball_listener {
        compatible = "zmk,input-listener";
        device = <&trackball>;
        input-processors = <&trackball_normal>;

        // レイヤー1: FUNCTION - 高精度モード（低速）
        layer_1 {
            layers = <1>;
            input-processors = <&trackball_slow>;
        };

        // レイヤー2: NUM - 標準モード
        layer_2 {
            layers = <2>;
            input-processors = <&trackball_normal>;
        };

        // レイヤー3: ARROW - 高速モード
        layer_3 {
            layers = <3>;
            input-processors = <&trackball_fast>;
        };

        // レイヤー4: MOUSE - 標準マウスモード
        layer_4 {
            layers = <4>;
            input-processors = <&trackball_normal>;
        };

        // レイヤー5: SCROLL - 精密スクロールモード
        layer_5 {
            layers = <5>;
            input-processors = <&trackball_scroll>;
        };

        // レイヤー6: システム - 低速モード（設定時の誤操作防止）
        layer_6 {
            layers = <6>;
            input-processors = <&trackball_slow>;
        };

        // レイヤー7: 複合レイヤー - 高速モード
        layer_7 {
            layers = <7>;
            input-processors = <&trackball_fast>;
        };
    };
};

&pinctrl {
    spi0_default: spi0_default {
        group1 {
            psels = <NRF_PSEL(SPIM_SCK, 0, 5)>,
                <NRF_PSEL(SPIM_MOSI, 0, 4)>,
                <NRF_PSEL(SPIM_MISO, 0, 4)>;
        };
    };

    spi0_sleep: spi0_sleep {
        group1 {
            psels = <NRF_PSEL(SPIM_SCK, 0, 5)>,
                <NRF_PSEL(SPIM_MOSI, 0, 4)>,
                <NRF_PSEL(SPIM_MISO, 0, 4)>;
            low-power-enable;
        };
    };
};

&xiao_serial { status = "disabled"; };

&spi0 {
    status = "okay";
    compatible = "nordic,nrf-spim";
    pinctrl-0 = <&spi0_default>;
    pinctrl-1 = <&spi0_sleep>;
    pinctrl-names = "default", "sleep";
    cs-gpios = <&gpio0 9 GPIO_ACTIVE_LOW>;

    trackball: trackball@0 {
        status = "okay";
        compatible = "pixart,pmw3610";
        reg = <0>;
        spi-max-frequency = <2000000>;
        irq-gpios = <&gpio0 2 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
        
        // 基本設定
        automouse-layer = <4>;
        scroll-layers = <5>;
        
        // 動的応答性の向上
        cpi = <1200>;
        evt-type = <INPUT_EV_REL>;
        x-input-code = <INPUT_REL_X>;
        y-input-code = <INPUT_REL_Y>;
        
        // 高応答性設定
        force-awake;
        smart-algorithm;
    };
};
